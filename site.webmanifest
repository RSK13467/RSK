{
  "name": "MD. Raiyan Sazid Khan - Portfolio Website",
  "short_name": "RSK",
  "description": "Future Developer & AI Enthusiast.",
  "start_url": "/RSK/",
  "scope": "/RSK/",
  "display": "standalone",
  "background_color": "#0f0c29",
  "theme_color": "#00f7ff",
  "orientation": "portrait-primary",  
  "lang": "en-US",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [],
  "icons": [
    {
      "src": "/RSK/favicon-16x16.png",
      "sizes": "16x16",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/RSK/favicon-32x32.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/RSK/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/RSK/android-chrome-192x192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/RSK/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/RSK/android-chrome-512x512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/RSK/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/RSK/screenshot-540x720.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Portfolio Homepage Mobile View"
    },
    {
      "src": "/RSK/screenshot-1280x720.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Portfolio Projects Section Desktop View"
    }
  ],
  "shortcuts": [
    {
      "name": "View Projects",
      "short_name": "Projects",
      "description": "Browse XZystrox AI, Creativity Sphere, and Custom Cipher projects",
      "url": "/RSK/#projects",
      "icons": [
        {
          "src": "/RSK/shortcut-projects-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Tech Stack",
      "short_name": "Skills",
      "description": "Explore expertise in HTML, CSS, JavaScript, and AI tools",
      "url": "/RSK/#skills",
      "icons": [
        {
          "src": "/RSK/shortcut-skills-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "AI Mastery",
      "short_name": "AI Tools",
      "description": "Discover proficiency with Gemini, Claude, ChatGPT, and more",
      "url": "/RSK/#ai-mastery",
      "icons": [
        {
          "src": "/RSK/shortcut-ai-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "screenshots_alt": [
    {
      "src": "/RSK/screenshot-mobile-hero.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Hero Section with Typing Animation"
    },
    {
      "src": "/RSK/screenshot-ai-grid.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AI Tools Grid - Gemini, Claude, ChatGPT, DeepSeek, and more"
    }
  ],
  "share_target": {
    "action": "/RSK/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "manifest_version": 3,
  "version": "1.0.0",
  "author": "MD. Raiyan Sazid Khan",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"]
}
